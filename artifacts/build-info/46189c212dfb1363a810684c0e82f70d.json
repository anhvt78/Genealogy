			"contracts/Genealogy/types/FamilyTypes.sol": {
				"content": "// SPDX-License-Identifier: MIT\r\npragma solidity ^0.8.20;\r\n\r\ncontract FamilyTypes {\r\n    enum ChildType {\r\n        BIOLOGICAL,\r\n        ADOPTED,\r\n        STEP\r\n    }\r\n    enum Sex {\r\n        MALE,\r\n        FEMALE,\r\n        UNDEFINE\r\n    }\r\n\r\n    struct Child {\r\n        ChildType childType;\r\n        bytes32 childId;\r\n    }\r\n\r\n    struct Spouse {\r\n        bytes32 spouseId;\r\n        bytes8 marriedDate;\r\n        bytes8 divorcedDate;\r\n    }\r\n\r\n\r\n    struct Person {\r\n        bytes name;\r\n        bytes32 fatherId;\r\n        bytes32 motherId;\r\n        Child[] children;\r\n        Spouse[] spouses;\r\n        Sex sex;\r\n        bytes8 birthDate;\r\n        bytes8 deathDate;\r\n        bytes shortDesc;\r\n    }\r\n}\r\n"
			}
		},
