			"contracts/Genealogy/FamilyTypes.sol": {
				"content": "// SPDX-License-Identifier: MIT\r\npragma solidity ^0.8.20;\r\n\r\nlibrary FamilyTypes {\r\n    // enum ChildType {\r\n    //     BIOLOGICAL,\r\n    //     ADOPTED,\r\n    //     STEP\r\n    // }\r\n    enum Sex {\r\n        MALE,\r\n        FEMALE,\r\n        UNDEFINE\r\n    }\r\n\r\n        // Cấu trúc mới để lưu ngày tháng linh hoạt\r\n    struct DateInfo {\r\n        uint8 day; \r\n        uint8 month; // 0 nếu không xác định\r\n          // 0 nếu không xác định\r\n        uint16 year;\r\n    }\r\n\r\n    // struct Child {\r\n    //     // ChildType childType;\r\n    //     bytes32 childId;\r\n    // }\r\n\r\n    // struct Spouse {\r\n    //     bytes32 spouseId;\r\n    //     DateInfo marriedDate;  // Cập nhật sang DateInfo\r\n    //     DateInfo divorcedDate; // Cập nhật sang DateInfo\r\n    // }\r\n\r\n\r\n    struct Person {\r\n        string name;          \r\n        bytes32 parentId;\r\n        // bytes32 motherId;\r\n        bytes32[] children;\r\n        bytes32[] spouses;\r\n        Sex sex;\r\n        DateInfo birthDate;   \r\n        DateInfo deathDate;    \r\n        string shortDesc;     \r\n    }\r\n}\r\n"
			}
		},
